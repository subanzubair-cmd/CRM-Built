{
  "name": "@crm/database",
  "version": "0.0.1",
  "private": true,
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts"
  },
  "scripts": {
    "db:migrate": "prisma migrate dev",
    "db:migrate:deploy": "prisma migrate deploy",
    "db:migrate:sequelize": "tsx src/migrations-umzug/cli.ts",
    "db:migrate:sequelize:status": "tsx src/migrations-umzug/cli.ts status",
    "db:migrate:sequelize:up": "tsx src/migrations-umzug/cli.ts up",
    "db:migrate:sequelize:down": "tsx src/migrations-umzug/cli.ts down",
    "db:seed": "tsx src/seed.ts",
    "db:studio": "prisma studio",
    "db:generate": "prisma generate",
    "test": "vitest run"
  },
  "dependencies": {
    "@prisma/adapter-pg": "^7.7.0",
    "@prisma/client": "^6.0.0",
    "bcryptjs": "^2.4.3",
    "decimal.js": "^10.4.3",
    "dotenv": "^16.4.0",
    "pg": "^8.20.0",
    "pg-hstore": "^2.3.4",
    "reflect-metadata": "^0.2.2",
    "sequelize": "^6.37.5",
    "sequelize-typescript": "^2.1.6",
    "umzug": "^3.8.2"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^20.0.0",
    "@types/pg": "^8.11.0",
    "@types/validator": "^13.12.2",
    "prisma": "^6.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.8.0",
    "vitest": "^2.1.8"
  }
}
