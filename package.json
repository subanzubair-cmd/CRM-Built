{
  "name": "homeward-crm",
  "private": true,
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "test": "turbo run test",
    "db:migrate": "pnpm --filter @crm/database run db:migrate",
    "db:migrate:status": "pnpm --filter @crm/database run db:migrate:status",
    "db:migrate:up": "pnpm --filter @crm/database run db:migrate:up",
    "db:migrate:down": "pnpm --filter @crm/database run db:migrate:down",
    "db:migrate:check": "bash scripts/check-migrations.sh",
    "db:seed": "pnpm --filter @crm/database run db:seed",
    "seed:leads": "tsx scripts/seed-leads.ts",
    "seed:dts-dta-leads": "tsx scripts/seed-dts-dta-leads.ts",
    "seed:all-pipelines": "tsx scripts/seed-all-pipelines.ts",
    "seed:lead-sources": "tsx scripts/seed-lead-sources.ts",
    "seed:comm-provider": "tsx scripts/seed-comm-provider.ts",
    "tunnel": "tsx scripts/tunnel.ts"
  },
  "devDependencies": {
    "@ngrok/ngrok": "^1.5.1",
    "dotenv": "^16.4.0",
    "tsx": "^4.19.0",
    "turbo": "^2.5.0",
    "typescript": "^5.8.0"
  },
  "packageManager": "pnpm@9.0.0",
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  }
}
