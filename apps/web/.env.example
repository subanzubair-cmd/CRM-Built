# ─────────────────────────────────────────────────────────────────────
# Homeward CRM — apps/web environment variables
# Copy this file to apps/web/.env.local and fill in your own values.
# .env.local is gitignored — never commit your real secrets.
# ─────────────────────────────────────────────────────────────────────

# ── Database ─────────────────────────────────────────────────────────
DATABASE_URL=postgres://crm:crm@localhost:5432/crm

# ── Auth (NextAuth) ──────────────────────────────────────────────────
AUTH_SECRET=replace-with-32-byte-random-string
NEXTAUTH_URL=http://localhost:3000

# ── Comm provider (used as fallback when no DB row is active) ────────
# Twilio
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_DEFAULT_NUMBER=
TWILIO_TWIML_HOST=http://localhost:3000

# Telnyx (alternative to Twilio — set in Settings → SMS Integration UI
# instead of env so secrets are encrypted at rest)

# ── Local webhook tunnel (ngrok) ─────────────────────────────────────
# Sign up free at https://dashboard.ngrok.com, then paste your token.
# Required for `pnpm tunnel`.
NGROK_AUTHTOKEN=

# Optional — paid ngrok plan only. Reserves a stable subdomain so the
# tunnel URL stays the same across restarts. Leave blank for a random
# *.ngrok-free.app URL.
# NGROK_DOMAIN=homewardpartners-dev.ngrok.app

# Optional — change the local port the tunnel forwards to. Defaults to 3000.
# TUNNEL_PORT=3000

# ── AI providers ─────────────────────────────────────────────────────
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# ── Encryption key for DB-stored provider secrets ───────────────────
# Used by /lib/crypto.ts to AES-encrypt CommProviderConfig.configJson
# values (Twilio/Telnyx tokens). Falls back to AUTH_SECRET if unset.
CONFIG_ENCRYPTION_KEY=
